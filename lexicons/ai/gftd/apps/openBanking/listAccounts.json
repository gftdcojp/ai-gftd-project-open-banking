{
  "lexicon": 1,
  "id": "ai.gftd.apps.openBanking.listAccounts",
  "defs": {
    "main": {
      "type": "query",
      "description": "List accounts owned by a DID. Paginated.",
      "parameters": {
        "type": "params",
        "required": ["ownerDid"],
        "properties": {
          "ownerDid": { "type": "string", "format": "did" },
          "status": { "type": "string", "enum": ["active", "frozen", "closed"] },
          "limit": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 },
          "offset": { "type": "integer", "minimum": 0, "default": 0 }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["accounts", "total", "offset", "limit"],
          "properties": {
            "accounts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "accountDid": { "type": "string", "format": "did" },
                  "accountNumber": { "type": "string" },
                  "accountType": { "type": "string" },
                  "currency": { "type": "string" },
                  "status": { "type": "string" },
                  "balance": { "type": "number" },
                  "displayName": { "type": "string" }
                }
              }
            },
            "total": { "type": "integer" },
            "offset": { "type": "integer" },
            "limit": { "type": "integer" }
          }
        }
      }
    }
  }
}
